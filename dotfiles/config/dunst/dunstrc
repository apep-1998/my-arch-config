# Dunst configuration — palette matches rofi rounded theme
# Colors: bg #212121, accent #F57C00, fg #E6E6E6

[global]
    monitor = 0
    follow = mouse

    width = (250, 420)
    height = (0, 200)
    origin = top-right
    offset = 16x48
    scale = 0
    notification_limit = 5

    progress_bar = true
    progress_bar_height = 8
    progress_bar_frame_width = 1
    progress_bar_min_width = 150
    progress_bar_max_width = 400

    indicate_hidden = yes
    transparency = 5
    separator_height = 2
    padding = 14
    horizontal_padding = 16
    text_icon_padding = 10
    frame_width = 2
    frame_color = "#F57C00"
    gap_size = 6
    separator_color = frame
    sort = yes

    font = JetBrainsMono Nerd Font 10
    line_height = 2
    markup = full
    format = "<b>%s</b>\n%b"
    alignment = left
    vertical_alignment = center
    show_age_threshold = 60
    ellipsize = middle
    ignore_newline = no
    stack_duplicates = true
    hide_duplicate_count = false
    show_indicators = yes

    icon_position = left
    min_icon_size = 32
    max_icon_size = 64
    icon_corner_radius = 6
    icon_theme = "Papirus-Dark, Adwaita"
    enable_recursive_icon_lookup = true

    corner_radius = 10
    corners = all

    sticky_history = yes
    history_length = 40

    dmenu = /usr/bin/rofi -dmenu -p dunst
    browser = /usr/bin/xdg-open

    always_run_script = true
    title = Dunst
    class = Dunst
    ignore_dbusclose = false

    mouse_left_click = close_current
    mouse_middle_click = do_action, close_current
    mouse_right_click = close_all

[urgency_low]
    background = "#212121"
    foreground = "#969696"
    frame_color = "#3D3D3D"
    timeout = 4
    default_icon = dialog-information

[urgency_normal]
    background = "#212121"
    foreground = "#E6E6E6"
    frame_color = "#F57C00"
    timeout = 6
    default_icon = dialog-information

[urgency_critical]
    background = "#2A1212"
    foreground = "#FFFFFF"
    frame_color = "#FF3B30"
    timeout = 0
    default_icon = dialog-warning

# ---- per-app overrides ----

[volume]
    appname = "volume"
    format = "<b>%s</b>"
    timeout = 2

[screenshot]
    summary = "Screenshot*"
    timeout = 3

[spotify]
    appname = "Spotify"
    timeout = 5
    new_icon = music
